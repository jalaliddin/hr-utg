APP_NAME="Urganchtransgaz HR"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=http://YOUR_VPS_IP_OR_DOMAIN
APP_LOCALE=uz
APP_TIMEZONE=Asia/Tashkent
APP_FALLBACK_LOCALE=uz

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=hr_prod
DB_USERNAME=hruser
DB_PASSWORD=YOUR_SECURE_DB_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=database
CACHE_STORE=database

FILESYSTEM_DISK=public

LOG_CHANNEL=stack
LOG_LEVEL=error

# Hikvision sozlamalari (ixtiyoriy)
# HIKVISION_TIMEOUT=30
